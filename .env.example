# Copy to .env and fill in real values. .env is gitignored — never commit it.
#
# 32-byte AES-256 master key that encrypts peppers at rest, base64-encoded.
# Generate one with:   head -c 32 /dev/urandom | base64
PEPPERMILL_STORAGE_KEY=

# The shared server credential your TelemetryForge servers present as a bearer
# token. Make it long and random, e.g.:   head -c 32 /dev/urandom | base64
PEPPERMILL_CREDENTIAL=
