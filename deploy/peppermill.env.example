# PepperMill configuration — installed to /etc/peppermill/peppermill.env (chmod 600, root-owned).
# systemd reads this as root before dropping to the service user, so the key never needs to be
# readable by the service account.
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5130

# REQUIRED — base64 of a 32-byte master key:  head -c 32 /dev/urandom | base64
PepperMill__StorageKeyBase64=

# Storage backend: File (default) or Postgres. The store lives in the systemd StateDirectory.
PepperMill__StorageProvider=File
PepperMill__StorePath=/var/lib/peppermill
# PepperMill__PostgresConnectionString=Host=…;Username=…;Password=…;Database=peppermill

# Allowlist your servers' registration callback hosts (needed to register sites), one per index:
# PepperMill__CallbackAllowedHosts__0=tf-server-1.internal
